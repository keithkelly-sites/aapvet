---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    name: 'Pet Dental Care',
    href: '/services/dental-care',
    image: '/images/dental-care.png',
    desc: 'Oral exams, cleanings, and extractions to keep your pet\'s mouth healthy and pain-free.',
  },
  {
    name: 'Pet Laser Therapy',
    href: '/services/laser-therapy',
    image: '/images/pet-laser-therapy.png',
    desc: 'Non-invasive cold laser treatments that reduce pain and inflammation, speeding recovery.',
  },
  {
    name: 'Preventative Care',
    href: '/services/preventative-care',
    image: '/images/pet-preventative-care.png',
    desc: 'Wellness exams, vaccinations, and parasite prevention tailored to your pet\'s life stage.',
  },
  {
    name: 'Nutritional Counseling',
    href: '/services/nutritional-counseling',
    image: '/images/dog-is-eating-food-from-bowl.jpg',
    desc: 'Personalized dietary guidance for every age, breed, and health condition.',
  },
  {
    name: 'In-House Pharmacy',
    href: '/services/pharmacy',
    image: '/images/pet-pharmacy2-1.jpg',
    desc: 'Authentic medications dispensed on-site for your pet\'s convenience and safety.',
  },
  {
    name: 'Pet Microchipping',
    href: '/services/microchipping',
    image: '/images/a-veterinarian-is-scanning-a-dog-for-microchip.jpg',
    desc: 'Quick, permanent identification to help reunite you with a lost pet.',
  },
  {
    name: 'Pain Management',
    href: '/services/pain-management',
    image: '/images/pet-pain-management.png',
    desc: 'Individualized, multimodal plans to keep your pet comfortable at every stage of life.',
  },
  {
    name: 'Pet Radiology',
    href: '/services/radiology',
    image: '/images/pet-x-ray-image-under-x-ray-machine.png',
    desc: 'Digital X-rays for fast, accurate diagnosis of injuries and internal conditions.',
  },
  {
    name: 'Pet Surgery',
    href: '/services/surgery',
    image: '/images/pet-surgery.png',
    desc: 'Spay, neuter, soft tissue, and dental surgeries with careful pre- and post-op support.',
  },
];
---

<Layout
  title="Veterinary Services | All About Pets Veterinary Hospital"
  description="Full-service veterinary care in Canonsburg and Washington, PA — dental care, laser therapy, surgery, radiology, pharmacy, and more. Serving cats and dogs."
>
  <!-- Hero -->
  <section class="bg-teal-mist py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-teal text-sm font-semibold uppercase tracking-wider mb-3">What We Offer</p>
        <h1 class="text-4xl sm:text-5xl font-bold text-charcoal leading-tight mb-6">
          Comprehensive Care Under One Roof
        </h1>
        <p class="text-slate text-lg leading-relaxed">
          From routine wellness visits to advanced diagnostics and surgery — All About Pets provides everything your cat or dog needs, at two convenient locations.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service, i) => (
          <a
            href={service.href}
            class="group bg-white rounded-xl overflow-hidden card-lift border border-border reveal"
            style={`animation-delay: ${i * 40}ms`}
          >
            <div class="aspect-[16/10] overflow-hidden bg-teal-mist">
              <img
                src={service.image}
                alt={service.name}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                width="400" height="250" loading="lazy"
              />
            </div>
            <div class="p-5">
              <div class="flex items-start justify-between gap-3 mb-2">
                <h2 class="font-display font-bold text-charcoal group-hover:text-teal transition-colors text-lg leading-snug">
                  {service.name}
                </h2>
                <svg class="w-4 h-4 text-slate group-hover:text-teal transition-colors shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
              <p class="text-slate text-sm leading-relaxed">{service.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-teal-pale py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <h2 class="text-3xl font-bold text-charcoal mb-4">Have Questions About a Service?</h2>
      <p class="text-slate mb-8 max-w-lg mx-auto">Our team is happy to talk through what your pet needs. Give us a call or send us a message.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/contact" class="btn btn-teal">
          Contact Us
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a href="tel:7247455503" class="btn btn-outline">(724) 745-5503</a>
      </div>
    </div>
  </section>
</Layout>
