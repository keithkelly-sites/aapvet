---
import Layout from '../layouts/Layout.astro';

const services = [
  { name: 'Dental Care', slug: 'dental-care', image: '/images/dental-care.jpg', desc: 'Professional pet dentistry to prevent and treat dental diseases.' },
  { name: 'Fully Stocked Pharmacy', slug: 'pharmacy', image: '/images/pet-pharmacy2-1.jpg', desc: 'In-house pharmacy for immediate access to medications.' },
  { name: 'Laser Therapy', slug: 'laser-therapy', image: '/images/pet-laser-therapy.jpg', desc: 'Non-invasive treatment to reduce pain and speed healing.' },
  { name: 'Microchipping', slug: 'microchipping', image: '/images/a-veterinarian-is-scanning-a-dog-for-microchip.jpg', desc: 'Permanent identification so lost pets find their way home.' },
  { name: 'Nutritional Counseling', slug: 'nutritional-counseling', image: '/images/dog-is-eating-food-from-bowl.jpg', desc: 'Diet plans tailored to your pet\'s age, breed, and health needs.' },
  { name: 'Preventative Care', slug: 'preventative-care', image: '/images/pet-preventative-care.jpg', desc: 'Vaccinations, wellness exams, and disease prevention.' },
  { name: 'Pain Management', slug: 'pain-management', image: '/images/pet-pain-management.jpg', desc: 'Multimodal approaches to keep your pet comfortable.' },
  { name: 'Radiology', slug: 'radiology', image: '/images/pet-x-ray-image-under-x-ray-machine.jpg', desc: 'Digital X-rays for fast, accurate diagnostics.' },
  { name: 'Surgery', slug: 'surgery', image: '/images/pet-surgery.jpg', desc: 'Soft tissue and routine surgical procedures with attentive monitoring.' },
];
---

<Layout
  title="Veterinary Services in Canonsburg, PA | All About Pets"
  description="Full-service veterinary care including dental, surgery, laser therapy, radiology, microchipping, and more. All About Pets Veterinary Hospital, Canonsburg & Washington, PA."
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">Our Services</p>
      <h1>Comprehensive Care<br/>for Cats & Dogs</h1>
      <div class="accent-bar"></div>
      <p class="hero-sub">
        At All About Pets Veterinary Hospital, your pets are in great hands. Our compassionate, skillful veterinary staff are here when you need us most.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="section">
    <div class="wrap-wide">
      <div class="services-grid">
        {services.map((service, i) => (
          <a href={`/services/${service.slug}`} class="service-card reveal" style={`--delay: ${i * 0.05}s`}>
            <div class="service-img">
              <img src={service.image} alt={service.name} class="img-cover" loading="lazy" />
              <div class="service-img-overlay"></div>
            </div>
            <div class="service-content">
              <h3>{service.name}</h3>
              <p>{service.desc}</p>
              <span class="service-arrow">&rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-light" style="text-align:center;">
    <div class="wrap">
      <h2>Questions About a Service?</h2>
      <p style="max-width:540px;margin-inline:auto;margin-bottom:var(--space-lg);color:var(--text-on-light-muted);">
        We're happy to discuss which services are right for your pet. Reach out anytime.
      </p>
      <a href="/contact" class="btn btn-warm">Contact Us</a>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding-top: calc(var(--nav-h) + var(--space-3xl));
    padding-bottom: var(--space-2xl);
    background: var(--dark);
    text-align: center;

    & h1 { margin-block: var(--space-sm) var(--space-md); }
    & .accent-bar { margin-inline: auto; }
  }

  .hero-sub {
    max-width: 560px;
    margin-inline: auto;
    margin-top: var(--space-lg);
    color: var(--text-on-dark-muted);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .service-card {
    display: block;
    text-decoration: none;
    background: var(--dark-raised);
    border: 1px solid var(--dark-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform 0.3s ease, border-color 0.3s ease;
    animation-delay: var(--delay);

    &:hover {
      transform: translateY(-6px);
      border-color: var(--warm);
    }
  }

  .service-img {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
  }

  .service-img img {
    transition: transform 0.4s ease;
  }

  .service-card:hover .service-img img {
    transform: scale(1.06);
  }

  .service-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, oklch(0.14 0.015 260 / 0.4) 0%, transparent 50%);
  }

  .service-content {
    padding: var(--space-lg);
    position: relative;
  }

  .service-content h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-xs);
    transition: color 0.2s;
  }

  .service-card:hover .service-content h3 {
    color: var(--warm);
  }

  .service-content p {
    font-size: var(--text-sm);
    color: var(--text-on-dark-muted);
    line-height: 1.6;
  }

  .service-arrow {
    position: absolute;
    top: var(--space-lg);
    right: var(--space-lg);
    font-size: var(--text-xl);
    color: var(--warm);
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity 0.25s, transform 0.25s;
  }

  .service-card:hover .service-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 900px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 500px) {
    .services-grid { grid-template-columns: 1fr; }
  }
</style>
