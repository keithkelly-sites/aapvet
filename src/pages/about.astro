---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About All About Pets Veterinary Hospital | Canonsburg, PA"
  description="Meet the compassionate team at All About Pets Veterinary Hospital. Learn about our mission, values, and commitment to quality care in Canonsburg and Washington, PA."
>
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">About Us</p>
      <h1>Where Every Pet<br/>Is Family</h1>
      <div class="accent-bar"></div>
    </div>
  </section>

  <!-- Mission -->
  <section class="section section-light">
    <div class="wrap">
      <div class="mission-layout">
        <div class="mission-text">
          <h2>Our Mission</h2>
          <p class="mission-statement">
            To deliver honest, compassionate, and personalized care for pet owners and their pets, caring for and cherishing each patient as the beloved family member they are.
          </p>
          <div class="accent-bar"></div>
        </div>
        <div class="mission-image reveal">
          <img src="/images/cat-and-dog.jpg" alt="Cat and dogs sitting together in bed" class="img-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Story -->
  <section class="section section-raised">
    <div class="wrap">
      <div class="story-content reveal">
        <h2>The Practice</h2>
        <p>
          All About Pets Veterinary Hospital serves Canonsburg, Washington, PA, and the surrounding communities. Led by Dr. Michele Sacksteder, a licensed and experienced veterinarian, the clinic delivers personalized care that puts your pet's health and happiness first.
        </p>
        <p>
          We believe pets are family. By maintaining a highly trained and compassionate staff, we make sure every pet receives the attentive care they deserve. We use only the safest and most effective vaccines, tailored to meet each pet's individual needs, and follow proven vaccination protocols to promote long-term wellness.
        </p>
        <p>
          Our hospital is equipped with modern, well-maintained technology to support accurate diagnostics and effective treatment. We stay current with progressive veterinary practices to educate and empower pet owners, so your companions live their healthiest lives.
        </p>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section">
    <div class="wrap">
      <h2 class="values-heading reveal">What Sets Us Apart</h2>
      <div class="values-grid">
        <div class="value-item reveal">
          <span class="value-number">01</span>
          <h3>Honest Care</h3>
          <p>We recommend only what your pet truly needs. No upselling, no unnecessary procedures.</p>
        </div>
        <div class="value-item reveal">
          <span class="value-number">02</span>
          <h3>Individual Attention</h3>
          <p>We take the time to know every patient by name. Your pet isn't a chart number here.</p>
        </div>
        <div class="value-item reveal">
          <span class="value-number">03</span>
          <h3>Modern Technology</h3>
          <p>Digital radiology, laser therapy, in-house pharmacy. The tools to get answers fast and treat effectively.</p>
        </div>
        <div class="value-item reveal">
          <span class="value-number">04</span>
          <h3>Two Locations</h3>
          <p>Canonsburg and Washington, PA. Open on alternating days so we're available when you need us.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-light cta-section">
    <div class="wrap" style="text-align:center;">
      <h2>Ready to Visit?</h2>
      <p style="max-width:540px;margin-inline:auto;margin-bottom:var(--space-lg);">
        We proudly serve pets in Canonsburg and Washington, PA, and the surrounding areas.
      </p>
      <div style="display:flex;gap:var(--space-sm);justify-content:center;flex-wrap:wrap;">
        <a href="/contact" class="btn btn-warm">Get in Touch</a>
        <a href="/team" class="btn btn-outline-dark">Meet the Team</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding-top: calc(var(--nav-h) + var(--space-3xl));
    padding-bottom: var(--space-2xl);
    background: var(--dark);
    text-align: center;

    & h1 { margin-block: var(--space-sm) var(--space-md); }
    & .accent-bar { margin-inline: auto; }
  }

  .mission-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .mission-statement {
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-size: var(--text-xl);
    font-style: italic;
    line-height: 1.5;
    color: var(--text-on-light);
    margin-block: var(--space-md) var(--space-lg);
  }

  .mission-image {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 5/4;
  }

  .story-content {
    max-width: 720px;
    margin-inline: auto;

    & h2 { margin-bottom: var(--space-lg); }
    & p { margin-bottom: var(--space-md); color: var(--text-on-dark-muted); }
    & p:last-child { margin-bottom: 0; }
  }

  .values-heading {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }

  .value-item {
    padding: var(--space-lg);
    border: 1px solid var(--dark-border);
    border-radius: var(--radius-lg);
    transition: border-color 0.3s;

    &:hover { border-color: var(--warm); }
  }

  .value-number {
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-size: var(--text-3xl);
    font-weight: 800;
    color: oklch(0.62 0.17 30 / 0.2);
    display: block;
    margin-bottom: var(--space-sm);
  }

  .value-item h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-xs);
  }

  .value-item p {
    color: var(--text-on-dark-muted);
    font-size: var(--text-sm);
  }

  @media (max-width: 700px) {
    .mission-layout { grid-template-columns: 1fr; }
    .values-grid { grid-template-columns: 1fr; }
  }
</style>
