---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
---

<Layout title="About Our Practice" description="Meet Dr. Michele Sacksteder and the team at All About Pets Veterinary Hospital. Two-location vet care built on compassion.">

  <!-- Page Hero -->
  <section class="bg-primary text-primary-foreground relative" style="clip-path: polygon(0 0, 100% 0, 100% 88%, 0 100%);">
    <div class="absolute inset-0 opacity-[0.02]" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(255,255,255,0.3) 10px, rgba(255,255,255,0.3) 11px);"></div>
    <div class="max-w-[1200px] mx-auto px-6 md:px-12 pt-16 md:pt-20 pb-24 md:pb-32 relative">
      <h1 class="text-primary-foreground mb-4">About All About Pets</h1>
      <p class="text-primary-foreground/80 text-lg max-w-2xl">A full-service hospital led by a veterinarian who treats every patient as a beloved family member.</p>
    </div>
  </section>

  <!-- Mission Statement -->
  <section class="bg-background">
    <div class="max-w-[680px] mx-auto px-6 md:px-12 py-16 md:py-20 text-center">
      <blockquote class="border-l-[3px] border-accent pl-6 text-left">
        <p class="text-lg italic text-foreground/80 leading-relaxed">Our mission is to deliver honest, compassionate, and personalized care for pet owners and their pets, caring for and cherishing each patient as the beloved family member they are.</p>
      </blockquote>
    </div>
  </section>

  <!-- Practice Description -->
  <section class="bg-background">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12 pb-16 md:pb-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-foreground/70 leading-relaxed mb-5">All About Pets Veterinary Hospital is a full-service veterinary hospital treating cats and dogs in Canonsburg and Washington, PA. Led by Dr. Michele Sacksteder, DVM, the clinic uses modern technology and continuous staff training to deliver individualized care.</p>
          <p class="text-foreground/70 leading-relaxed mb-5">We believe pets are family, and our mission reflects this commitment. By maintaining a highly trained and compassionate staff, we ensure every pet receives the attentive care they deserve. We use only the safest and most effective vaccines, tailored to meet each pet's individual needs, and adhere to proven vaccination protocols to promote long-term wellness.</p>
          <p class="text-foreground/70 leading-relaxed">Our hospital is equipped with modern, well-maintained technology to support accurate diagnostics and effective treatment. We are committed to providing the most current, progressive information to educate and empower pet owners, ensuring your beloved companions live their healthiest lives.</p>
        </div>
        <div class="rounded-2xl overflow-hidden">
          <Image
            src="/images/cat-and-dog.jpg"
            alt="Cat and dog sitting together in bed"
            width={560}
            height={448}
            class="w-full h-auto object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Meet the Veterinarian -->
  <section class="bg-muted">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12 py-16 md:py-20">
      <div class="grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-10 items-start">
        <div class="rounded-xl overflow-hidden">
          <Image
            src="/images/michele.webp"
            alt="Dr. Michele Sacksteder, DVM, Practice Owner"
            width={320}
            height={320}
            class="w-full h-auto object-cover aspect-square"
            loading="lazy"
          />
        </div>
        <div>
          <h2 class="mb-2">Dr. Michele Sacksteder, DVM</h2>
          <p class="text-accent font-semibold mb-4">Practice Owner</p>
          <p class="text-foreground/70 leading-relaxed mb-4">Dr. Sacksteder is a licensed, experienced veterinarian with a lifelong dedication to pet care. She leads the team at All About Pets Veterinary Hospital, where she is known for her thorough approach, genuine compassion, and personal connection with every patient and client who visits.</p>
          <p class="text-foreground/70 leading-relaxed">[PLACEHOLDER: Extended bio for Dr. Sacksteder, if available. No additional biographical details were found in the scraped content beyond her title and role.]</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Meet the Staff -->
  <section class="bg-background">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12 py-16 md:py-20">
      <h2 class="mb-10">The People Behind Your Pet's Care</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {[
          { name: 'Jon', title: 'Management Staff', img: '/images/jon.webp' },
          { name: 'Erin', title: 'Client Service Specialist', img: '/images/erin.webp' },
          { name: 'Amy', title: '[PLACEHOLDER: Staff title]', img: '/images/amy.webp' },
          { name: 'Arica', title: '[PLACEHOLDER: Staff title]', img: '/images/arica.webp' },
        ].map(member => (
          <div class="border-t-2 border-accent bg-background rounded-lg overflow-hidden shadow-[0_1px_3px_rgba(28,28,26,0.06),0_4px_12px_rgba(28,28,26,0.04)]">
            <Image
              src={member.img}
              alt={`${member.name}, ${member.title}`}
              width={280}
              height={280}
              class="w-full aspect-square object-cover"
              loading="lazy"
            />
            <div class="p-4">
              <p class="font-display font-semibold text-foreground">{member.name}</p>
              <p class="text-sm text-foreground/60">{member.title}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- All Six Testimonials -->
  <section class="bg-muted">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12 py-16 md:py-20">
      <h2 class="mb-10">From Our Clients</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          { quote: "First-time visit, and I was very pleased with the outcome. They were super polite and professional. Extremely knowledgeable, too, which shouldn't have to be said but unfortunately needs to be, and it was very much appreciated. They were very sweet and patient with my 2 Pits. Normally when I say I have a Pit they turn me away, but not them. They were so welcoming and showed my babies love.", author: 'Jelsamina C.' },
          { quote: "Dr. Sacksteder and her staff have gone above and beyond to take care of my pup. She's a rescue with lots of anxiety and doesn't do well with strangers, but they've all been so patient and understanding and have worked with her every step of the way to provide the best care possible. I'll never take my pets anywhere else.", author: 'Becky P.' },
          { quote: "Been coming here for years. It's the level of care, compassion, and love they have for our animals that keeps us coming back. Amazing people!", author: 'Patrick K.' },
          { quote: "Dr. S is so thorough and caring. She listens and takes the time to answer all questions and concerns and help my Georgie feel better. Highly recommend this vet.", author: 'Susan F.' },
          { quote: "I had a wonderful experience with Dr. S and my two elderly cats. The whole staff was very caring, and it's obvious they have pride in what they do. I didn't feel rushed, and they took the time to talk with me about medication and different options. Very happy I took my babies there!", author: 'Rachel B.' },
          { quote: "All About Pets is hands down the best veterinary clinic. Dr. S. and her staff are so compassionate and caring for every pet that comes through the door. Dr. S. is always eager to give you a hug and assure you everything will be okay. When you leave, you know your pet is in good hands, and she and her staff are doing everything possible to keep your pet healthy. Thank you for taking such good care of our precious Sophie.", author: 'Ruth F.' },
        ].map(testimonial => (
          <article class="border-l-[3px] border-accent pl-5 pr-4 py-4 bg-background rounded-r-lg">
            <blockquote class="text-sm italic text-foreground/70 leading-relaxed mb-4">&ldquo;{testimonial.quote}&rdquo;</blockquote>
            <p class="font-display font-semibold text-sm text-foreground">{testimonial.author}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Band -->
  <section class="bg-primary">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12 py-14 md:py-16 text-center">
      <h2 class="text-primary-foreground mb-6">Your pets deserve care this personal.</h2>
      <a href="/contact" class="inline-flex items-center bg-accent text-accent-foreground font-semibold px-8 py-3.5 rounded-full text-sm hover:bg-accent/90">Schedule a Visit</a>
    </div>
  </section>

</Layout>
