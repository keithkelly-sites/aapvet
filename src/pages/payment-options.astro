---
import Layout from '../layouts/Layout.astro';

const careCreditBenefits = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>`,
    label: 'Extended Payment Plans',
    desc: 'Spread the cost of care over time with flexible monthly payments that fit your budget.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
    label: 'Interest-Free for 6 Months',
    desc: 'Pay no interest when you pay your balance in full within the promotional period.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
    label: 'Quick & Easy Approval',
    desc: 'Apply in minutes online or in our office. Most decisions come back instantly.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
    label: 'Immediate Access to Funds',
    desc: "Once approved, you can use your CareCredit account right away — no waiting.",
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>`,
    label: 'No Annual Fee',
    desc: 'Keep your CareCredit card year-round for any future veterinary needs — no annual charge.',
  },
];
---

<Layout
  title="Payment Options | All About Pets Veterinary Hospital"
  description="All About Pets accepts credit cards, debit cards, cash, and CareCredit financing. Learn about our flexible payment options for veterinary care in Canonsburg, PA."
>
  <!-- Hero -->
  <section class="bg-teal-mist py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-teal text-sm font-semibold uppercase tracking-wider mb-3">Flexible Payments</p>
        <h1 class="text-4xl sm:text-5xl font-bold text-charcoal leading-tight mb-6">
          Payment Options That Work for Your Family
        </h1>
        <p class="text-slate text-lg leading-relaxed">
          We want the best care to be accessible. We accept several payment methods and offer CareCredit financing so your pet gets what they need, when they need it.
        </p>
      </div>
    </div>
  </section>

  <!-- Accepted Payments -->
  <section class="py-16 lg:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl reveal">
        <h2 class="text-3xl font-bold text-charcoal mb-8">We Accept</h2>
        <div class="grid sm:grid-cols-3 gap-5">
          <div class="bg-white border border-border rounded-xl p-6 text-center card-lift">
            <div class="w-12 h-12 rounded-full bg-teal-pale flex items-center justify-center mx-auto mb-3">
              <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
              </svg>
            </div>
            <p class="font-display font-bold text-charcoal">Credit Cards</p>
            <p class="text-slate text-xs mt-1">Visa, Mastercard, Discover, Amex</p>
          </div>
          <div class="bg-white border border-border rounded-xl p-6 text-center card-lift">
            <div class="w-12 h-12 rounded-full bg-teal-pale flex items-center justify-center mx-auto mb-3">
              <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
            </div>
            <p class="font-display font-bold text-charcoal">Debit Cards</p>
            <p class="text-slate text-xs mt-1">All major debit cards accepted</p>
          </div>
          <div class="bg-white border border-border rounded-xl p-6 text-center card-lift">
            <div class="w-12 h-12 rounded-full bg-teal-pale flex items-center justify-center mx-auto mb-3">
              <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <p class="font-display font-bold text-charcoal">Cash</p>
            <p class="text-slate text-xs mt-1">Always welcome</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CareCredit -->
  <section class="bg-sand py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <!-- Left: intro -->
        <div class="reveal">
          <p class="text-teal text-sm font-semibold uppercase tracking-wider mb-3">Financing</p>
          <h2 class="text-3xl md:text-4xl font-bold text-charcoal mb-5">
            CareCredit — Veterinary Financing Made Simple
          </h2>
          <p class="text-slate leading-relaxed mb-6">
            CareCredit is a healthcare credit card designed specifically for health, wellness, and veterinary expenses. It lets you pay for your pet's care today and manage the cost over time — so you never have to choose between your budget and your pet's health.
          </p>
          <p class="text-slate leading-relaxed mb-8">
            We encourage clients to apply before a visit so you're ready when you need it. Approval is quick, and once you have your card it can be used for any future veterinary, dental, or healthcare expense.
          </p>
          <a href="https://www.carecredit.com/" target="_blank" rel="noopener noreferrer" class="btn btn-teal">
            Apply for CareCredit
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
          <div class="mt-8">
            <img
              src="/images/carecredit-logo.jpg"
              alt="CareCredit — Healthcare Financing"
              class="h-10 w-auto"
              width="200" height="40" loading="lazy"
            />
          </div>
        </div>

        <!-- Right: benefits -->
        <div class="space-y-4 reveal">
          {careCreditBenefits.map(b => (
            <div class="bg-white rounded-xl p-5 border border-border flex items-start gap-4 card-lift">
              <div class="w-10 h-10 rounded-full bg-teal-pale flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <Fragment set:html={b.icon} />
                </svg>
              </div>
              <div>
                <p class="font-display font-bold text-charcoal">{b.label}</p>
                <p class="text-slate text-sm mt-1 leading-relaxed">{b.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Questions CTA -->
  <section class="py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <h2 class="text-3xl font-bold text-charcoal mb-4">Questions About Payment?</h2>
      <p class="text-slate mb-8 max-w-lg mx-auto">Our front desk team is happy to walk you through your options before or after your visit. Don't let cost be a barrier to your pet's health.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/contact" class="btn btn-teal">Contact Us</a>
        <a href="tel:7247455503" class="btn btn-outline">(724) 745-5503</a>
      </div>
    </div>
  </section>
</Layout>
