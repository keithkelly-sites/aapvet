---
import Layout from '../layouts/Layout.astro';

const testimonials = [
  {
    name: 'Jelsamina C.',
    text: 'First-time visit, and I was very pleased with the outcome. They were super polite and professional. Extremely knowledgeable, too. They were very sweet and patient with my 2 Pits. Normally when I say I have a Pit they turn me away, but not them — they were so welcoming and showed my babies love.',
  },
  {
    name: 'Becky P.',
    text: "Dr. Sacksteder and her staff have gone above and beyond to take care of my pup. She's a rescue with lots of anxiety and doesn't do well with strangers, but they've all been so patient and understanding. I'll never take my pets anywhere else.",
  },
  {
    name: 'Patrick K.',
    text: "Been coming here for years. It's the level of care, compassion, and love they have for our animals that keeps us coming back. Amazing people!",
  },
  {
    name: 'Susan F.',
    text: 'Dr. S is so thorough and caring. She listens and takes the time to answer all questions and concerns and help my Georgie feel better. Highly recommend this vet.',
  },
  {
    name: 'Rachel B.',
    text: "I had a wonderful experience with Dr. S and my two elderly cats. The whole staff was very caring, and it's obvious they have pride in what they do. I didn't feel rushed.",
  },
  {
    name: 'Ruth F.',
    text: "All About Pets is hands down the best veterinary clinic. Dr. S. and her staff are so compassionate and caring for every pet that comes through the door. Dr. S. is always eager to give you a hug and assure you everything will be okay.",
  },
];
---

<Layout
  title="Client Reviews | All About Pets Veterinary Hospital"
  description="See what pet owners in Canonsburg and Washington, PA say about All About Pets Veterinary Hospital and Dr. Michele Sacksteder. Read our Google reviews."
>
  <!-- Hero -->
  <section class="bg-teal-mist py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-teal text-sm font-semibold uppercase tracking-wider mb-3">What People Say</p>
        <h1 class="text-4xl sm:text-5xl font-bold text-charcoal leading-tight mb-6">
          Trusted by Families Across Southwestern PA
        </h1>
        <p class="text-slate text-lg leading-relaxed">
          We let our clients do the talking. Here's what pet owners say about the care they receive at All About Pets.
        </p>
      </div>
    </div>
  </section>

  <!-- Testimonials Grid -->
  <section class="py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {testimonials.map((t, i) => (
          <div
            class="bg-white rounded-xl p-7 border border-border card-lift reveal flex flex-col"
            style={`animation-delay: ${i * 50}ms`}
          >
            <!-- Stars -->
            <div class="flex gap-0.5 mb-4" aria-label="5 stars">
              {Array.from({ length: 5 }).map(() => (
                <svg class="w-4 h-4 text-peach fill-current" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <blockquote class="text-slate leading-relaxed text-sm flex-1 mb-5">
              "{t.text}"
            </blockquote>
            <div class="flex items-center gap-2 pt-4 border-t border-border">
              <div class="w-8 h-8 rounded-full bg-teal-pale flex items-center justify-center shrink-0">
                <span class="text-teal font-bold text-xs">{t.name.charAt(0)}</span>
              </div>
              <cite class="not-italic font-display font-semibold text-charcoal text-sm">{t.name}</cite>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Google CTA -->
  <section class="bg-sand py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <div class="w-14 h-14 rounded-full bg-white border border-border flex items-center justify-center mx-auto mb-5 shadow-sm">
        <svg class="w-7 h-7" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
      </div>
      <h2 class="text-3xl font-bold text-charcoal mb-4">See All Our Google Reviews</h2>
      <p class="text-slate mb-8 max-w-lg mx-auto">Hundreds of pet owners in the Canonsburg and Washington area have shared their experiences. Read them all on Google.</p>
      <a
        href="https://www.google.com/search?q=All+About+Pets+Veterinary+Hospital++Canonsburg%2C+PA#lrd=0x8834547e771ffda9:0xac2cbc96bb6f0240,1,,,,"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-teal"
      >
        Read Reviews on Google
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <h2 class="text-3xl font-bold text-charcoal mb-4">Experience It Yourself</h2>
      <p class="text-slate mb-8 max-w-lg mx-auto">Join the families who trust All About Pets with the animals they love most. We'd love to meet your pet.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/contact" class="btn btn-teal">Schedule a Visit</a>
        <a href="tel:7247455503" class="btn btn-outline">(724) 745-5503</a>
      </div>
    </div>
  </section>
</Layout>
