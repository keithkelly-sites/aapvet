---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Us | All About Pets Veterinary Hospital"
  description="Contact All About Pets Veterinary Hospital in Canonsburg and Washington, PA. Call, text, or send a message online. Two convenient locations serving southwestern PA."
>
  <!-- Hero -->
  <section class="bg-teal-mist py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-teal text-sm font-semibold uppercase tracking-wider mb-3">Get In Touch</p>
        <h1 class="text-4xl sm:text-5xl font-bold text-charcoal leading-tight mb-6">
          We'd Love to Meet Your Pet
        </h1>
        <p class="text-slate text-lg leading-relaxed">
          Call, text, or fill out the form below. We're at two locations across southwestern PA, and we'll get back to you as quickly as we can.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact grid -->
  <section class="py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12">

        <!-- Form -->
        <div class="lg:col-span-3 reveal">
          <h2 class="text-2xl font-bold text-charcoal mb-6">Send Us a Message</h2>
          <p class="text-sm text-teal bg-teal-mist rounded-lg px-4 py-3 mb-6 form-notice">This form will be active once the site is live.</p>
          <form
            action="#"
            method="POST"
            class="space-y-5"
            id="contact-form"
          >
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="firstName" class="block text-sm font-semibold text-charcoal mb-1.5">First Name <span class="text-teal" aria-hidden="true">*</span></label>
                <input
                  type="text"
                  id="firstName"
                  name="firstName"
                  required
                  autocomplete="given-name"
                  class="w-full px-4 py-3 rounded-lg border border-border bg-white text-charcoal text-sm placeholder-slate/50 focus:outline-none focus:ring-2 focus:ring-teal/30 focus:border-teal transition-colors"
                  placeholder="Jane"
                />
              </div>
              <div>
                <label for="lastName" class="block text-sm font-semibold text-charcoal mb-1.5">Last Name <span class="text-teal" aria-hidden="true">*</span></label>
                <input
                  type="text"
                  id="lastName"
                  name="lastName"
                  required
                  autocomplete="family-name"
                  class="w-full px-4 py-3 rounded-lg border border-border bg-white text-charcoal text-sm placeholder-slate/50 focus:outline-none focus:ring-2 focus:ring-teal/30 focus:border-teal transition-colors"
                  placeholder="Smith"
                />
              </div>
            </div>
            <div>
              <label for="email" class="block text-sm font-semibold text-charcoal mb-1.5">Email Address <span class="text-teal" aria-hidden="true">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                class="w-full px-4 py-3 rounded-lg border border-border bg-white text-charcoal text-sm placeholder-slate/50 focus:outline-none focus:ring-2 focus:ring-teal/30 focus:border-teal transition-colors"
                placeholder="jane@example.com"
              />
            </div>
            <div>
              <label for="phone" class="block text-sm font-semibold text-charcoal mb-1.5">Phone Number</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                autocomplete="tel"
                class="w-full px-4 py-3 rounded-lg border border-border bg-white text-charcoal text-sm placeholder-slate/50 focus:outline-none focus:ring-2 focus:ring-teal/30 focus:border-teal transition-colors"
                placeholder="(724) 000-0000"
              />
            </div>
            <div>
              <label for="message" class="block text-sm font-semibold text-charcoal mb-1.5">Message <span class="text-teal" aria-hidden="true">*</span></label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                class="w-full px-4 py-3 rounded-lg border border-border bg-white text-charcoal text-sm placeholder-slate/50 focus:outline-none focus:ring-2 focus:ring-teal/30 focus:border-teal transition-colors resize-none"
                placeholder="Tell us about your pet and how we can help…"
              ></textarea>
            </div>
            <button type="submit" class="btn btn-teal w-full justify-center">
              Send Message
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
              </svg>
            </button>
          </form>
        </div>

        <!-- Info panel -->
        <div class="lg:col-span-2 space-y-6 reveal">
          <!-- Phone / Email -->
          <div class="bg-teal-pale rounded-xl p-6">
            <h3 class="font-display font-bold text-charcoal mb-4">Reach Us Directly</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-full bg-teal flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-slate font-medium uppercase tracking-wider">Phone</p>
                  <a href="tel:7247455503" class="text-charcoal font-semibold hover:text-teal transition-colors">(724) 745-5503</a>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-full bg-teal flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-slate font-medium uppercase tracking-wider">Text</p>
                  <a href="sms:7246338216" class="text-charcoal font-semibold hover:text-teal transition-colors">(724) 633-8216</a>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-full bg-teal flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-slate font-medium uppercase tracking-wider">Email</p>
                  <a href="mailto:allaboutpets@aapvet.com" class="text-charcoal font-semibold hover:text-teal transition-colors break-all">allaboutpets@aapvet.com</a>
                </div>
              </li>
            </ul>
          </div>

          <!-- Canonsburg -->
          <div class="bg-white border border-border rounded-xl p-6">
            <h3 class="font-display font-bold text-charcoal mb-1">Canonsburg Location</h3>
            <address class="not-italic text-slate text-sm mt-3 space-y-1">
              <p>
                <a href="https://goo.gl/maps/QMbPWvmcKiK28B9aA" target="_blank" rel="noopener noreferrer" class="hover:text-teal transition-colors underline underline-offset-2 decoration-border">
                  155 E Pike St, Canonsburg, PA 15317
                </a>
              </p>
            </address>
            <div class="mt-4 space-y-1.5">
              <div class="flex items-center gap-2 text-sm">
                <svg class="w-4 h-4 text-teal shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-charcoal font-medium">Mon</span>
                <span class="text-slate">7:00 AM – 4:00 PM</span>
              </div>
              <div class="flex items-center gap-2 text-sm">
                <svg class="w-4 h-4 text-teal shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-charcoal font-medium">Wed</span>
                <span class="text-slate">10:00 AM – 7:00 PM</span>
              </div>
              <div class="flex items-center gap-2 text-sm">
                <svg class="w-4 h-4 text-teal shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-charcoal font-medium">Fri</span>
                <span class="text-slate">7:00 AM – 12:00 PM</span>
              </div>
            </div>
          </div>

          <!-- Washington -->
          <div class="bg-white border border-border rounded-xl p-6">
            <h3 class="font-display font-bold text-charcoal mb-1">Washington Location</h3>
            <address class="not-italic text-slate text-sm mt-3 space-y-1">
              <p>
                <a href="https://goo.gl/maps/xhbDRCDundaSHjyHA" target="_blank" rel="noopener noreferrer" class="hover:text-teal transition-colors underline underline-offset-2 decoration-border">
                  829 Jefferson Ave, Washington, PA 15301
                </a>
              </p>
            </address>
            <div class="mt-4 space-y-1.5">
              <div class="flex items-center gap-2 text-sm">
                <svg class="w-4 h-4 text-teal shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-charcoal font-medium">Tue</span>
                <span class="text-slate">7:00 AM – 4:00 PM</span>
              </div>
              <div class="flex items-center gap-2 text-sm">
                <svg class="w-4 h-4 text-teal shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-charcoal font-medium">Thu</span>
                <span class="text-slate">10:00 AM – 7:00 PM</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
