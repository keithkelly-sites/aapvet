---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact All About Pets Veterinary Hospital | Canonsburg & Washington, PA"
  description="Get in touch with All About Pets Veterinary Hospital. Two locations in Canonsburg and Washington, PA. Call, text, or email us."
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">Contact</p>
      <h1>Get in Touch</h1>
      <div class="accent-bar"></div>
      <p class="hero-sub">For appointments, questions, or anything else, reach out by phone, text, or email.</p>
    </div>
  </section>

  <!-- Contact Methods -->
  <section class="section section-raised">
    <div class="wrap">
      <div class="contact-methods">
        <a href="tel:7247455503" class="contact-card card reveal">
          <div class="contact-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <h3>Call Us</h3>
          <p class="contact-value">(724) 745-5503</p>
        </a>

        <a href="sms:7246338216" class="contact-card card reveal">
          <div class="contact-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <h3>Text Us</h3>
          <p class="contact-value">(724) 633-8216</p>
        </a>

        <a href="mailto:allaboutpets@aapvet.com" class="contact-card card reveal">
          <div class="contact-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <h3>Email</h3>
          <p class="contact-value">allaboutpets@aapvet.com</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Locations -->
  <section class="section section-light">
    <div class="wrap">
      <h2 style="text-align:center;margin-bottom:var(--space-2xl);color:var(--text-on-light);">Our Locations</h2>
      <div class="locations-grid">
        <div class="location-card card-light reveal">
          <div class="location-header">
            <h3>Canonsburg</h3>
          </div>
          <div class="location-body">
            <address>
              <a href="https://goo.gl/maps/QMbPWvmcKiK28B9aA" target="_blank" rel="noopener noreferrer">
                155 E Pike St<br/>Canonsburg, PA 15317
              </a>
            </address>
            <div class="location-hours">
              <h4>Hours</h4>
              <dl>
                <div><dt>Monday</dt><dd>7:00 AM – 4:00 PM</dd></div>
                <div><dt>Tuesday</dt><dd>Closed</dd></div>
                <div><dt>Wednesday</dt><dd>10:00 AM – 7:00 PM</dd></div>
                <div><dt>Thursday</dt><dd>Closed</dd></div>
                <div><dt>Friday</dt><dd>7:00 AM – 12:00 PM</dd></div>
                <div><dt>Saturday</dt><dd>Closed</dd></div>
                <div><dt>Sunday</dt><dd>Closed</dd></div>
              </dl>
            </div>
            <a href="https://goo.gl/maps/QMbPWvmcKiK28B9aA" target="_blank" rel="noopener noreferrer" class="btn btn-outline-dark" style="margin-top:var(--space-md);">Get Directions</a>
          </div>
        </div>

        <div class="location-card card-light reveal">
          <div class="location-header">
            <h3>Washington</h3>
          </div>
          <div class="location-body">
            <address>
              <a href="https://goo.gl/maps/xhbDRCDundaSHjyHA" target="_blank" rel="noopener noreferrer">
                829 Jefferson Ave<br/>Washington, PA 15301
              </a>
            </address>
            <div class="location-hours">
              <h4>Hours</h4>
              <dl>
                <div><dt>Monday</dt><dd>Closed</dd></div>
                <div><dt>Tuesday</dt><dd>7:00 AM – 4:00 PM</dd></div>
                <div><dt>Wednesday</dt><dd>Closed</dd></div>
                <div><dt>Thursday</dt><dd>10:00 AM – 7:00 PM</dd></div>
                <div><dt>Friday</dt><dd>Closed</dd></div>
                <div><dt>Saturday</dt><dd>Closed</dd></div>
                <div><dt>Sunday</dt><dd>Closed</dd></div>
              </dl>
            </div>
            <a href="https://goo.gl/maps/xhbDRCDundaSHjyHA" target="_blank" rel="noopener noreferrer" class="btn btn-outline-dark" style="margin-top:var(--space-md);">Get Directions</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="section section-raised">
    <div class="wrap" style="max-width:640px;">
      <h2 style="text-align:center;margin-bottom:var(--space-xl);">Send Us a Message</h2>
      <form action="https://api.keithkelly.dev/contact/aapvet" method="POST" class="contact-form">
        <div class="form-row">
          <div class="form-group">
            <label for="first-name">First Name <span class="required" aria-hidden="true">*</span></label>
            <input type="text" id="first-name" name="first_name" required autocomplete="given-name" />
          </div>
          <div class="form-group">
            <label for="last-name">Last Name <span class="required" aria-hidden="true">*</span></label>
            <input type="text" id="last-name" name="last_name" required autocomplete="family-name" />
          </div>
        </div>
        <div class="form-group">
          <label for="email">Email <span class="required" aria-hidden="true">*</span></label>
          <input type="email" id="email" name="email" required autocomplete="email" />
        </div>
        <div class="form-group">
          <label for="phone">Phone</label>
          <input type="tel" id="phone" name="phone" autocomplete="tel" />
        </div>
        <div class="form-group">
          <label for="message">How can we help you? <span class="required" aria-hidden="true">*</span></label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>
        <p class="form-required-note"><span class="required" aria-hidden="true">*</span> Required fields</p>
        <button type="submit" class="btn btn-warm" style="width:100%;justify-content:center;">Submit</button>
      </form>
    </div>
  </section>

  <!-- Payment Options -->
  <section class="section">
    <div class="wrap" style="max-width:700px;text-align:center;">
      <h2>Payment Options</h2>
      <p style="color:var(--text-on-dark-muted);margin-block:var(--space-md) var(--space-lg);">
        We accept all major credit cards, debit cards, cash, and CareCredit. CareCredit lets you say yes to the best treatment for your pet and pay over time with monthly payments that fit your budget.
      </p>
      <div class="payment-logos">
        <img src="/images/carecredit-logo.jpg" alt="CareCredit" width="160" height="87" loading="lazy" class="carecredit-logo" />
      </div>
    </div>
  </section>

  <!-- Online Pharmacy -->
  <section class="section section-raised" style="text-align:center;">
    <div class="wrap">
      <h2>Online Pharmacy</h2>
      <p style="max-width:540px;margin-inline:auto;margin-block:var(--space-md) var(--space-lg);color:var(--text-on-dark-muted);">
        Order your pet's medications, food, and supplies from our online pharmacy and have them shipped right to your door.
      </p>
      <a href="https://aapvetcanonsburg.vetsfirstchoice.com/" target="_blank" rel="noopener noreferrer" class="btn btn-warm">Visit Online Pharmacy</a>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding-top: calc(var(--nav-h) + var(--space-3xl));
    padding-bottom: var(--space-2xl);
    background: var(--dark);
    text-align: center;

    & h1 { margin-block: var(--space-sm) var(--space-md); }
    & .accent-bar { margin-inline: auto; }
  }

  .hero-sub {
    max-width: 520px;
    margin-inline: auto;
    margin-top: var(--space-lg);
    color: var(--text-on-dark-muted);
  }

  /* Contact Methods */
  .contact-methods {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .contact-card {
    padding: var(--space-xl);
    text-align: center;
    text-decoration: none;
  }

  .contact-icon {
    color: var(--warm);
    margin-bottom: var(--space-md);
  }

  .contact-card h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-xs);
  }

  .contact-value {
    color: var(--text-on-dark-muted);
    font-size: var(--text-sm);
  }

  /* Locations */
  .locations-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
  }

  .location-card {
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid oklch(0.22 0.015 260 / 0.08);
  }

  .location-header h3 {
    color: var(--text-on-light);
    margin-bottom: var(--space-md);
  }

  .location-body address {
    font-style: normal;
    font-size: var(--text-base);
    line-height: 1.6;
    margin-bottom: var(--space-lg);
  }

  .location-body address a {
    color: var(--warm);
    &:hover { color: var(--warm-hover); }
  }

  .location-hours h4 {
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-on-light-muted);
    margin-bottom: var(--space-sm);
  }

  .location-hours dl {
    font-size: var(--text-sm);
  }

  .location-hours dl div {
    display: flex;
    justify-content: space-between;
    padding-block: 0.3em;
    border-bottom: 1px solid oklch(0.22 0.015 260 / 0.06);
  }

  .location-hours dt {
    color: var(--text-on-light);
    font-weight: 500;
  }

  .location-hours dd {
    color: var(--text-on-light-muted);
  }

  .carecredit-logo {
    border-radius: var(--radius);
    margin-inline: auto;
  }

  /* Contact Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .form-group label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-on-dark);
  }

  .required {
    color: var(--warm);
  }

  .form-group input,
  .form-group textarea {
    background: var(--dark);
    border: 1px solid var(--dark-border);
    border-radius: var(--radius);
    padding: 0.75em 1em;
    color: var(--cream);
    font-size: var(--text-base);
    transition: border-color 0.2s;
    min-height: 44px;

    &:focus {
      border-color: var(--warm);
      outline: 2px solid var(--warm);
      outline-offset: 1px;
    }
  }

  .form-group textarea {
    resize: vertical;
  }

  .form-required-note {
    font-size: var(--text-xs);
    color: var(--text-on-dark-muted);
  }

  @media (max-width: 700px) {
    .contact-methods { grid-template-columns: 1fr; }
    .locations-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
