---
import Layout from '../layouts/Layout.astro';

/** @type application/ld+json — rendered via Layout */
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "VeterinaryCare",
  "name": "All About Pets Veterinary Hospital",
  "description": "Full-service veterinary hospital treating cats and dogs in Canonsburg and Washington, PA.",
  "url": "https://aapvet.keithkelly.dev",
  "telephone": "(724) 745-5503",
  "email": "allaboutpets@aapvet.com",
  "address": [
    { "@type": "PostalAddress", "streetAddress": "155 E Pike St", "addressLocality": "Canonsburg", "addressRegion": "PA", "postalCode": "15317" },
    { "@type": "PostalAddress", "streetAddress": "829 Jefferson Ave", "addressLocality": "Washington", "addressRegion": "PA", "postalCode": "15301" }
  ],
  "image": "https://aapvet.keithkelly.dev/images/cat-and-dog.jpg",
  "priceRange": "$$",
  "sameAs": ["https://www.facebook.com/aapvet/"]
};

const services = [
  { name: 'Dental Care', href: '/services/dental-care', image: '/images/dental-care.png' },
  { name: 'Laser Therapy', href: '/services/laser-therapy', image: '/images/pet-laser-therapy.png' },
  { name: 'Preventative Care', href: '/services/preventative-care', image: '/images/pet-preventative-care.png' },
  { name: 'Surgery', href: '/services/surgery', image: '/images/pet-surgery.png' },
  { name: 'Pharmacy', href: '/services/pharmacy', image: '/images/pet-pharmacy2-1.jpg' },
  { name: 'Radiology', href: '/services/radiology', image: '/images/pet-x-ray-image-under-x-ray-machine.png' },
];
---

<Layout
  title="All About Pets Veterinary Hospital | Canonsburg & Washington, PA"
  description="Full-service veterinary hospital treating cats and dogs in Canonsburg and Washington, PA. Led by Dr. Michele Sacksteder, DVM. Honest, compassionate, personalized care."
  jsonLd={jsonLd}
>
  <!-- Hero — open, personal -->
  <section class="bg-teal-mist">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20 lg:py-28">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div>
          <p class="text-teal text-sm font-semibold uppercase tracking-wider mb-4">Canonsburg & Washington, PA</p>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-charcoal leading-[1.1] mb-6">
            Your Pets Are<br />Family. We Treat<br />Them That Way.
          </h1>
          <p class="text-slate text-lg leading-relaxed max-w-md mb-8">
            Honest, compassionate, individualized care from Dr. Michele Sacksteder and her team — two locations serving the greater Pittsburgh area.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/contact" class="btn btn-teal">
              Schedule a Visit
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
            <a href="tel:7247455503" class="btn btn-outline">(724) 745-5503</a>
          </div>
        </div>
        <div>
          <img
            src="/images/cat-and-dog.jpg"
            alt="A happy cat and dog together"
            class="w-full rounded-2xl shadow-xl object-cover aspect-[4/3]"
            width="640" height="480" loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Dr. Michele — the heart of the practice -->
  <section class="py-20 lg:py-28">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="grid md:grid-cols-5 gap-10 items-start reveal">
          <div class="md:col-span-2">
            <img
              src="/images/michele.webp"
              alt="Dr. Michele Sacksteder, DVM"
              class="w-full rounded-xl shadow-md object-cover aspect-[3/4]"
              width="320" height="427" loading="lazy"
            />
            <div class="mt-4">
              <p class="font-display font-bold text-charcoal">Dr. Michele Sacksteder</p>
              <p class="text-teal text-sm font-medium">DVM, Practice Owner</p>
            </div>
          </div>
          <div class="md:col-span-3">
            <blockquote class="text-xl lg:text-2xl text-charcoal leading-relaxed italic mb-6">
              "Our mission is to deliver honest, compassionate, and personalized care for pet owners and their pets, caring for and cherishing each patient as the beloved family member they are."
            </blockquote>
            <p class="text-slate leading-relaxed mb-6">
              All About Pets Veterinary Hospital is a full-service veterinary hospital treating cats and dogs in Canonsburg and Washington, PA. We use modern technology and continuous staff training to deliver individualized care — because every pet deserves a team that truly knows them.
            </p>
            <a href="/about" class="btn btn-outline text-sm">Meet the Full Team</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services — clean grid -->
  <section class="bg-sand py-20 lg:py-28">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-12 reveal">
        <div>
          <p class="text-teal text-sm font-semibold uppercase tracking-wider mb-2">What We Do</p>
          <h2 class="text-3xl md:text-4xl font-bold text-charcoal">Our Services</h2>
        </div>
        <a href="/services" class="text-teal font-semibold text-sm hover:text-teal-dark transition-colors">
          View all 9 services →
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 reveal">
        {services.map(s => (
          <a href={s.href} class="group bg-white rounded-xl overflow-hidden card-lift border border-border">
            <div class="aspect-[16/10] overflow-hidden bg-teal-mist">
              <img src={s.image} alt={s.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" width="400" height="250" loading="lazy" />
            </div>
            <div class="px-5 py-4 flex items-center justify-between">
              <h3 class="font-display font-semibold text-charcoal group-hover:text-teal transition-colors">{s.name}</h3>
              <svg class="w-4 h-4 text-slate group-hover:text-teal transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonial — one powerful quote -->
  <section class="py-20 lg:py-28">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <svg class="w-10 h-10 text-teal-pale mx-auto mb-6" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" /></svg>
      <blockquote class="text-xl md:text-2xl text-charcoal leading-relaxed mb-8">
        They were very sweet and patient with my 2 Pits. Normally when I say I have a Pit they turn me away, but not them — they were so welcoming and showed my babies love.
      </blockquote>
      <cite class="not-italic text-slate font-medium">— Jelsamina C.</cite>
      <div class="mt-8">
        <a href="/testimonials" class="btn btn-outline text-sm">Read More Reviews</a>
      </div>
    </div>
  </section>

  <!-- Two Locations -->
  <section class="bg-teal py-16 lg:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-white">Two Locations to Serve You</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6 reveal">
        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-8 border border-white/10">
          <h3 class="font-display text-lg font-bold text-white mb-4">Canonsburg</h3>
          <address class="not-italic text-white/80 text-sm space-y-2">
            <p><a href="https://goo.gl/maps/QMbPWvmcKiK28B9aA" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors underline underline-offset-4 decoration-white/30">155 E Pike St, Canonsburg, PA 15317</a></p>
          </address>
          <div class="text-sm text-white/60 mt-4 space-y-1">
            <p>Monday: 7:00 AM – 4:00 PM</p>
            <p>Wednesday: 10:00 AM – 7:00 PM</p>
            <p>Friday: 7:00 AM – 12:00 PM</p>
          </div>
        </div>
        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-8 border border-white/10">
          <h3 class="font-display text-lg font-bold text-white mb-4">Washington</h3>
          <address class="not-italic text-white/80 text-sm space-y-2">
            <p><a href="https://goo.gl/maps/xhbDRCDundaSHjyHA" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors underline underline-offset-4 decoration-white/30">829 Jefferson Ave, Washington, PA 15301</a></p>
          </address>
          <div class="text-sm text-white/60 mt-4 space-y-1">
            <p>Tuesday: 7:00 AM – 4:00 PM</p>
            <p>Thursday: 10:00 AM – 7:00 PM</p>
          </div>
        </div>
      </div>
      <div class="text-center mt-8">
        <a href="/contact" class="btn btn-white">Contact Us</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 lg:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <img src="/images/img-2.jpg" alt="Happy golden retriever" class="w-24 h-24 rounded-full object-cover mx-auto mb-6 shadow-md" width="96" height="96" loading="lazy" />
      <h2 class="text-3xl md:text-4xl font-bold text-charcoal mb-4">Your Pets Deserve the Best</h2>
      <p class="text-slate mb-8 max-w-lg mx-auto">We proudly serve pets in Canonsburg, Washington, PA, and the surrounding areas. Schedule a visit and see why our clients never take their pets anywhere else.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/contact" class="btn btn-teal">Schedule a Visit</a>
        <a href="tel:7247455503" class="btn btn-outline">(724) 745-5503</a>
      </div>
    </div>
  </section>
</Layout>
