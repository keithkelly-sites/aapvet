---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  h1: string;
  intro: string;
  image: string;
  imageAlt: string;
}

const { title, description, h1, intro, image, imageAlt } = Astro.props;

const serviceLinks = [
  { href: '/services/dental-care', label: 'Pet Dental Care' },
  { href: '/services/pharmacy', label: 'In-House Pharmacy' },
  { href: '/services/laser-therapy', label: 'Pet Laser Therapy' },
  { href: '/services/microchipping', label: 'Pet Microchipping' },
  { href: '/services/nutritional-counseling', label: 'Nutritional Counseling' },
  { href: '/services/preventative-care', label: 'Preventative Care' },
  { href: '/services/pain-management', label: 'Pain Management' },
  { href: '/services/radiology', label: 'Pet Radiology' },
  { href: '/services/surgery', label: 'Pet Surgery' },
];

const currentPath = Astro.url.pathname;
---

<Layout title={title} description={description}>
  <!-- Hero with breadcrumb -->
  <section class="bg-teal-mist py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-1.5 text-xs text-slate mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-teal transition-colors">Home</a>
        <svg class="w-3 h-3 text-slate/40" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <a href="/services" class="hover:text-teal transition-colors">Services</a>
        <svg class="w-3 h-3 text-slate/40" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-charcoal font-medium" aria-current="page">{h1}</span>
      </nav>

      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <div>
          <h1 class="text-4xl sm:text-5xl font-bold text-charcoal leading-tight mb-5">{h1}</h1>
          <p class="text-slate text-lg leading-relaxed">{intro}</p>
        </div>
        <div>
          <img
            src={image}
            alt={imageAlt}
            class="w-full rounded-2xl shadow-lg object-cover aspect-[16/10]"
            width="640" height="400" loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Body -->
  <section class="py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12">

        <!-- Main content -->
        <div class="lg:col-span-2 prose-custom reveal">
          <slot />
        </div>

        <!-- Sidebar -->
        <aside class="space-y-6">
          <!-- All services nav -->
          <div class="bg-sand rounded-xl p-6 border border-border reveal">
            <h2 class="font-display font-bold text-charcoal text-sm uppercase tracking-wider mb-4">All Services</h2>
            <nav aria-label="Services navigation">
              <ul class="space-y-1">
                {serviceLinks.map(link => (
                  <li>
                    <a
                      href={link.href}
                      class:list={[
                        'flex items-center justify-between px-3 py-2 rounded-lg text-sm transition-colors',
                        currentPath === link.href
                          ? 'bg-teal-pale text-teal font-semibold'
                          : 'text-slate hover:text-teal hover:bg-teal-mist'
                      ]}
                      aria-current={currentPath === link.href ? 'page' : undefined}
                    >
                      {link.label}
                      {currentPath === link.href && (
                        <svg class="w-3.5 h-3.5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                      )}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>

          <!-- Contact card -->
          <div class="bg-teal rounded-xl p-6 reveal">
            <h2 class="font-display font-bold text-white mb-2">Have Questions?</h2>
            <p class="text-white/80 text-sm mb-5 leading-relaxed">Our team is happy to answer any questions about this service or schedule a visit.</p>
            <a href="/contact" class="btn btn-white w-full justify-center text-sm !py-2.5">
              Contact Us
            </a>
            <a href="tel:7247455503" class="mt-2 flex items-center justify-center gap-2 text-white/80 text-sm font-medium hover:text-white transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              (724) 745-5503
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-teal-pale py-14 lg:py-16 reveal">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-charcoal mb-4">Ready to Schedule?</h2>
      <p class="text-slate mb-7 max-w-lg mx-auto">Two locations in Canonsburg and Washington, PA. Call us or send a message — we'll get back to you quickly.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/contact" class="btn btn-teal">
          Request a Visit
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a href="tel:7247455503" class="btn btn-outline">(724) 745-5503</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .prose-custom :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-charcoal);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-custom :global(h3) {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-charcoal);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose-custom :global(p) {
    color: var(--color-slate);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .prose-custom :global(ul) {
    margin: 1rem 0 1.25rem 0;
    space-y: 0.5rem;
  }
  .prose-custom :global(li) {
    color: var(--color-slate);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin-bottom: 0.625rem;
    padding-left: 1.25rem;
    position: relative;
  }
  .prose-custom :global(li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55rem;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-teal);
  }
  .prose-custom :global(li strong) {
    color: var(--color-charcoal);
  }
  .prose-custom :global(a) {
    color: var(--color-teal);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose-custom :global(a:hover) {
    color: var(--color-teal-dark);
  }
  .prose-custom :global(.callout) {
    background: var(--color-teal-mist);
    border-left: 3px solid var(--color-teal);
    border-radius: 0 0.5rem 0.5rem 0;
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
  }
  .prose-custom :global(.callout p) {
    margin: 0;
    color: var(--color-charcoal);
    font-size: 0.9375rem;
  }
</style>
