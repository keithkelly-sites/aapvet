---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  heroImage: string;
  heroAlt: string;
  serviceName: string;
}

const { title, description, heroImage, heroAlt, serviceName } = Astro.props;

const allServices = [
  { name: 'Dental Care', slug: 'dental-care' },
  { name: 'Pharmacy', slug: 'pharmacy' },
  { name: 'Laser Therapy', slug: 'laser-therapy' },
  { name: 'Microchipping', slug: 'microchipping' },
  { name: 'Nutritional Counseling', slug: 'nutritional-counseling' },
  { name: 'Preventative Care', slug: 'preventative-care' },
  { name: 'Pain Management', slug: 'pain-management' },
  { name: 'Radiology', slug: 'radiology' },
  { name: 'Surgery', slug: 'surgery' },
];

const otherServices = allServices.filter(s => s.name !== serviceName);
---

<Layout title={title} description={description}>
  <!-- Service Hero -->
  <section class="svc-hero">
    <div class="svc-hero-img">
      <img src={heroImage} alt={heroAlt} class="img-cover" />
      <div class="svc-hero-overlay"></div>
    </div>
    <div class="svc-hero-text wrap">
      <p class="eyebrow">Our Services</p>
      <h1>{serviceName}</h1>
    </div>
  </section>

  <!-- Content -->
  <section class="section">
    <div class="wrap svc-content">
      <slot />
    </div>
  </section>

  <!-- Other Services -->
  <section class="section section-raised">
    <div class="wrap">
      <h2 style="text-align:center;margin-bottom:var(--space-xl);font-size:var(--text-2xl);">Other Services</h2>
      <div class="other-services">
        {otherServices.map(s => (
          <a href={`/services/${s.slug}`} class="other-svc-link">{s.name} &rarr;</a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-light" style="text-align:center;">
    <div class="wrap">
      <h2>Schedule an Appointment</h2>
      <p style="max-width:500px;margin-inline:auto;margin-bottom:var(--space-lg);color:var(--text-on-light-muted);">
        Contact All About Pets Veterinary Hospital in Canonsburg, PA. Our team is here to help.
      </p>
      <a href="/contact" class="btn btn-warm">Get in Touch</a>
    </div>
  </section>
</Layout>

<style>
  .svc-hero {
    position: relative;
    height: clamp(300px, 45vh, 500px);
    display: flex;
    align-items: flex-end;
  }

  .svc-hero-img {
    position: absolute;
    inset: 0;
  }

  .svc-hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .svc-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      oklch(0.14 0.015 260 / 0.9) 0%,
      oklch(0.14 0.015 260 / 0.5) 40%,
      oklch(0.14 0.015 260 / 0.3) 100%
    );
  }

  .svc-hero-text {
    position: relative;
    padding-bottom: var(--space-xl);

    & h1 { margin-top: var(--space-sm); }
  }

  .svc-content {
    max-width: 740px;

    & h2 {
      font-size: var(--text-2xl);
      margin-block: var(--space-xl) var(--space-md);
    }

    & h3 {
      font-size: var(--text-xl);
      margin-block: var(--space-lg) var(--space-sm);
    }

    & p {
      color: var(--text-on-dark-muted);
      margin-bottom: var(--space-md);
    }

    & ul {
      margin-bottom: var(--space-md);
      padding-left: 1.2em;
    }

    & li {
      color: var(--text-on-dark-muted);
      padding-block: 0.3em;
      list-style: disc;
    }

    & li::marker {
      color: var(--warm);
    }
  }

  .other-services {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm) var(--space-md);
  }

  .other-svc-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-on-dark-muted);
    padding: 0.5em 1em;
    border: 1px solid var(--dark-border);
    border-radius: var(--radius);
    transition: all 0.2s;

    &:hover {
      color: var(--warm);
      border-color: var(--warm);
    }
  }
</style>
