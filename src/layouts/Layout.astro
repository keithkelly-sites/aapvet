---
import '../styles/global.css';
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const businessName = 'All About Pets Veterinary Hospital';
const currentPath = Astro.url.pathname;
const canonicalURL = Astro.url.href;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/contact', label: 'Contact' },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} | {businessName}</title>
  <meta name="description" content={description} />

  <meta property="og:title" content={`${title} | ${businessName}`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  {ogImage && <meta property="og:image" content={ogImage} />}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | ${businessName}`} />
  <meta name="twitter:description" content={description} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}

  <link rel="canonical" href={canonicalURL} />

  <link rel="icon" href="/images/all-about-pets-veterinary-hospital-logo.jpg" type="image/jpeg" />

  <Font cssVariable="--font-display" preload />
  <Font cssVariable="--font-body" preload />
  <ClientRouter />

  <script async src="https://api.keithkelly.dev/d/s"></script>
  <script>window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};plausible.init({endpoint:"https://api.keithkelly.dev/d/e"})</script>
</head>
<body>
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-primary focus:text-primary-foreground focus:px-4 focus:py-2 focus:rounded-md">Skip to content</a>

  <header class="sticky top-0 z-50 bg-background/95 backdrop-blur-sm border-b border-border">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12 flex items-center justify-between h-18">
      <a href="/" class="flex items-center gap-3 opacity-100 hover:opacity-100">
        <span class="font-display font-bold text-lg text-primary tracking-tight">All About Pets</span>
      </a>

      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium tracking-wide uppercase',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-primary font-semibold border-b-2 border-primary pb-0.5'
                : 'text-foreground/70 hover:text-primary'
            ]}
            aria-current={currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
        <a href="tel:7247455503" class="inline-flex items-center gap-2 bg-primary text-primary-foreground text-sm font-semibold px-5 py-2.5 rounded-full hover:bg-primary/90">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          (724) 745-5503
        </a>
      </nav>

      <button id="menu-toggle" class="md:hidden p-2 text-foreground" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" /></svg>
        <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>

    <nav id="mobile-menu" hidden class="md:hidden bg-background border-t border-border">
      <div class="px-6 py-4 flex flex-col gap-3">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'text-base font-medium py-2 border-b border-border/50',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-primary font-semibold'
                : 'text-foreground/80'
            ]}
            aria-current={currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
        <a href="tel:7247455503" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground text-sm font-semibold px-5 py-3 rounded-full mt-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          (724) 745-5503
        </a>
      </div>
    </nav>
  </header>

  <main id="main-content">
    <slot />
  </main>

  <footer class="bg-[#1c1c1a] text-white/80">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12 py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div>
          <h3 class="font-display font-bold text-white text-lg mb-4">All About Pets</h3>
          <p class="text-sm leading-relaxed text-white/60 mb-6">Honest, compassionate, and personalized care for pet owners and their pets. We cherish each patient as the beloved family member they are.</p>
          <a href="https://www.facebook.com/aapvet/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-white/60 hover:text-white text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            Facebook
          </a>
        </div>

        <div>
          <h3 class="font-display font-bold text-white text-lg mb-4">Quick Links</h3>
          <nav class="flex flex-col gap-2.5">
            <a href="/" class="text-sm text-white/60 hover:text-white">Home</a>
            <a href="/about" class="text-sm text-white/60 hover:text-white">About</a>
            <a href="/services" class="text-sm text-white/60 hover:text-white">Services</a>
            <a href="/contact" class="text-sm text-white/60 hover:text-white">Contact</a>
            <a href="https://aapvetcanonsburg.vetsfirstchoice.com/" target="_blank" rel="noopener noreferrer" class="text-sm text-white/60 hover:text-white">Online Pharmacy</a>
          </nav>
        </div>

        <div>
          <h3 class="font-display font-bold text-white text-lg mb-4">Our Locations</h3>
          <div class="space-y-5">
            <div>
              <p class="text-sm font-semibold text-accent mb-1">Canonsburg</p>
              <p class="text-sm text-white/60">155 E Pike St, Canonsburg, PA 15317</p>
              <p class="text-sm text-white/60">Phone: <a href="tel:7247455503" class="text-white/80 hover:text-white">(724) 745-5503</a></p>
              <p class="text-sm text-white/60">Mon 7am-4pm, Wed 10am-7pm, Fri 7am-12pm</p>
            </div>
            <div>
              <p class="text-sm font-semibold text-accent mb-1">Washington</p>
              <p class="text-sm text-white/60">829 Jefferson Ave, Washington, PA 15301</p>
              <p class="text-sm text-white/60">Phone: <a href="tel:7246338216" class="text-white/80 hover:text-white">(724) 633-8216</a></p>
              <p class="text-sm text-white/60">Tue 7am-4pm, Thu 10am-7pm</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="border-t border-white/10">
      <div class="max-w-[1200px] mx-auto px-6 md:px-12 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
        <p class="text-xs text-white/40">&copy; {new Date().getFullYear()} All About Pets Veterinary Hospital. All rights reserved.</p>
        <p class="text-xs text-white/40">
          <a href="mailto:allaboutpets@aapvet.com" class="text-white/40 hover:text-white/60">allaboutpets@aapvet.com</a>
        </p>
      </div>
    </div>
  </footer>
</body>
</html>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    menu.hidden = expanded;
    iconOpen?.classList.toggle('hidden', !expanded);
    iconClose?.classList.toggle('hidden', expanded);
  });
</script>
