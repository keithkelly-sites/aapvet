---
import '../styles/global.css';
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
}

const { title, description, canonical, ogImage, jsonLd } = Astro.props;
const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).href;
const ogImg = ogImage || '/images/cat-and-dog.jpg';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/testimonials', label: 'Reviews' },
  { href: '/payment-options', label: 'Payment' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={new URL(ogImg, Astro.site).href} />
  <meta property="og:site_name" content="All About Pets Veterinary Hospital" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImg, Astro.site).href} />
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  <link rel="icon" type="image/jpeg" href="/images/logo.jpg" />
  <Font cssVariable="--font-display" />
  <Font cssVariable="--font-body" />
  <ClientRouter />
  <script defer data-domain="aapvet.keithkelly.dev" src="https://api.keithkelly.dev/d/s/script.js"></script>
</head>
<body class="min-h-screen flex flex-col">
  <a href="#main-content" class="skip-link">Skip to content</a>

  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-border" id="site-header">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-18">
        <a href="/" class="flex items-center gap-3" aria-label="All About Pets — Home">
          <img src="/images/logo.jpg" alt="All About Pets Veterinary Hospital" class="h-10 w-auto rounded" width="152" height="40" />
        </a>

        <nav class="hidden lg:flex items-center gap-0.5" aria-label="Main navigation">
          {navLinks.map(link => (
            <a
              href={link.href}
              class:list={[
                'px-3 py-1.5 rounded-md text-sm transition-colors',
                currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                  ? 'bg-teal-pale text-teal font-semibold'
                  : 'text-slate hover:text-teal hover:bg-teal-mist'
              ]}
            >
              {link.label}
            </a>
          ))}
          <a href="https://aapvetcanonsburg.vetsfirstchoice.com/" target="_blank" rel="noopener noreferrer"
             class="px-3 py-1.5 rounded-md text-sm text-slate hover:text-teal hover:bg-teal-mist transition-colors">
            Pharmacy
            <svg class="inline w-3 h-3 ml-0.5 -mt-0.5 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        </nav>

        <div class="hidden lg:flex items-center gap-3">
          <a href="tel:7247455503" class="text-sm text-teal font-semibold hover:text-teal-dark transition-colors">(724) 745-5503</a>
          <a href="/contact" class="btn btn-teal !text-xs !py-2 !px-4">Book Visit</a>
        </div>

        <button id="mobile-menu-btn" class="lg:hidden p-2 text-slate" aria-label="Open menu" aria-expanded="false">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
        </button>
      </div>
    </div>

    <div id="mobile-nav" class="mobile-nav fixed inset-0 z-50 bg-white lg:hidden" aria-hidden="true">
      <div class="flex items-center justify-between h-18 px-4 sm:px-6 border-b border-border">
        <img src="/images/logo.jpg" alt="All About Pets" class="h-10 w-auto rounded" width="152" height="40" />
        <button id="mobile-close-btn" class="p-2 text-slate" aria-label="Close menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
      <nav class="px-6 py-6 flex flex-col gap-1" aria-label="Mobile navigation">
        {navLinks.map(link => (
          <a href={link.href} class:list={['px-4 py-3 rounded-lg text-lg transition-colors', currentPath === link.href ? 'text-teal bg-teal-pale font-semibold' : 'text-slate hover:text-teal']}>
            {link.label}
          </a>
        ))}
        <div class="mt-6 pt-6 border-t border-border space-y-3">
          <a href="tel:7247455503" class="btn btn-outline justify-center w-full">(724) 745-5503</a>
          <a href="/contact" class="btn btn-teal justify-center w-full">Book a Visit</a>
        </div>
      </nav>
    </div>
  </header>

  <main id="main-content" class="flex-1">
    <slot />
  </main>

  <footer class="bg-charcoal text-white/70">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-10">
        <div class="lg:col-span-2">
          <img src="/images/logo-transparent.png" alt="All About Pets Veterinary Hospital" class="h-10 w-auto invert brightness-200" width="152" height="40" />
          <p class="text-sm mt-4 leading-relaxed max-w-sm">Honest, compassionate, individualized care — treating your pets as the beloved family members they are.</p>
          <a href="https://www.facebook.com/aapvet/" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="inline-block mt-4 text-white/40 hover:text-teal-light transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" /></svg>
          </a>
        </div>
        <div>
          <h3 class="font-display text-sm font-bold text-white uppercase tracking-wider mb-4">Canonsburg</h3>
          <address class="not-italic text-sm space-y-1">
            <p><a href="https://goo.gl/maps/QMbPWvmcKiK28B9aA" target="_blank" rel="noopener noreferrer" class="hover:text-teal-light transition-colors">155 E Pike St<br />Canonsburg, PA 15317</a></p>
          </address>
          <div class="text-xs mt-3 space-y-0.5 text-white/50">
            <p>Mon 7am–4pm</p>
            <p>Wed 10am–7pm</p>
            <p>Fri 7am–12pm</p>
          </div>
        </div>
        <div>
          <h3 class="font-display text-sm font-bold text-white uppercase tracking-wider mb-4">Washington</h3>
          <address class="not-italic text-sm space-y-1">
            <p><a href="https://goo.gl/maps/xhbDRCDundaSHjyHA" target="_blank" rel="noopener noreferrer" class="hover:text-teal-light transition-colors">829 Jefferson Ave<br />Washington, PA 15301</a></p>
          </address>
          <div class="text-xs mt-3 space-y-0.5 text-white/50">
            <p>Tue 7am–4pm</p>
            <p>Thu 10am–7pm</p>
          </div>
        </div>
      </div>
      <div class="mt-12 pt-6 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/40">
        <p>&copy; {new Date().getFullYear()} All About Pets Veterinary Hospital</p>
        <div class="flex items-center gap-4">
          <a href="tel:7247455503" class="hover:text-white/60 transition-colors">(724) 745-5503</a>
          <span class="text-white/20">·</span>
          <span>Text: <a href="sms:7246338216" class="hover:text-white/60 transition-colors">(724) 633-8216</a></span>
          <span class="text-white/20">·</span>
          <a href="mailto:allaboutpets@aapvet.com" class="hover:text-white/60 transition-colors">allaboutpets@aapvet.com</a>
        </div>
      </div>
    </div>
  </footer>

  <script>
    const menuBtn = document.getElementById('mobile-menu-btn');
    const closeBtn = document.getElementById('mobile-close-btn');
    const mobileNav = document.getElementById('mobile-nav');
    function open() { mobileNav?.classList.add('open'); mobileNav?.setAttribute('aria-hidden','false'); menuBtn?.setAttribute('aria-expanded','true'); document.body.style.overflow='hidden'; }
    function close() { mobileNav?.classList.remove('open'); mobileNav?.setAttribute('aria-hidden','true'); menuBtn?.setAttribute('aria-expanded','false'); document.body.style.overflow=''; }
    menuBtn?.addEventListener('click', open);
    closeBtn?.addEventListener('click', close);
    mobileNav?.querySelectorAll('a').forEach(l => l.addEventListener('click', close));
  </script>
</body>
</html>
